{
  "expo": {
    "name": "Friend Tracker",
    "slug": "friend-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "friend-tracker",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.402systems.friendtracker"
    },
    "android": {
      "package": "com.fourzerotwo.friendtracker",
      "adaptiveIcon": {
        "backgroundColor": "#f8fafc",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "plugins": ["expo-router", "expo-notifications"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
